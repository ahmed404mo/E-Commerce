{
  "name": "ecommerce-app",
  "version": "1.0.0",
  "private": true,
  "main": "electron.js",
  "author": "ahmed404mo",
  "description": "E-commerce React Application",
  "homepage": "https://ahmed404mo.github.io/E-Commerce",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@splidejs/react-splide": "^0.7.12",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "axios": "^1.12.1",
    "bootstrap": "^5.3.8",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.0",
    "react-scripts": "^5.0.1",
    "typed.js": "^2.1.0",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "electron": "electron .",
    "electron-dev": "set ELECTRON_IS_DEV=1 && electron .",
    "dist": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "clean-build": "rm -rf dist-electron dist build && npm run build && electron-builder --dir"
  },
  "build": {
    "extends": null,
    "appId": "com.ecommerce.app",
    "productName": "Ecommerce App",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron.js"
    },
    "win": {
      "target": "nsis",
      "executableName": "EcommerceStore"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^24.13.3",
    "gh-pages": "^6.3.0",
    "sass": "^1.90.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
